# Copie para C:\Apps\Editor\apps\ai-dashboard\.env no VPS
# Ajuste SESSION_SECRET e senha do Postgres antes de producao.

DATABASE_URL="postgresql://ai_dashboard:ai_dashboard@localhost:5432/ai_dashboard?schema=public"
SESSION_SECRET="troque-por-um-segredo-longo-aleatorio-min-32-chars"

APP_ORIGIN="https://princyai.com"
API_HOST="0.0.0.0"
API_PORT="3210"

WORKSPACE_STORAGE_ROOT="C:/Apps/Editor/apps/ai-dashboard/workspace-storage"
EDITOR_PROJECT_ROOT="C:/Apps/Editor"

AI_PROVIDER="ollama"
OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_CHAT_MODEL="deepseek-coder"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# Chat rapido no dashboard (desliga orquestrador/RAG pesado)
PRINCY_SIMPLE_MODE="true"
PRINCY_RAG_ENABLED="false"
PRINCY_PUBLIC_CHAT="true"

CODE_WEB_URL="https://princyai.com"
PRINCY_CORS_ORIGINS="https://princyai.com,https://www.princyai.com,https://dashboard.princyai.com,http://127.0.0.1:3200"

AGENT_API_TOKEN=""
AGENT_WORKSPACE_NAME="Princy Ai Web"

OPENAI_API_KEY=""
GROQ_API_KEY=""
GOOGLE_AI_API_KEY=""
DEEPSEEK_API_KEY=""
HUGGINGFACE_API_KEY=""

RAG_MAX_CHUNKS="6"
RAG_CHUNK_SIZE="1200"
