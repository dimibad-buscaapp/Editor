# =============================================================================
# Princy Ai — producao VPS (C:\Apps\Editor\apps\ai-dashboard\.env)
# =============================================================================
# Mapa de URLs (Caddy :443 -> portas internas no IP 108.181.169.40):
#   https://princyai.com/              -> :3220  index / landing
#   https://princyai.com/webeditor/    -> :3200  Code-OSS Web
#   https://princyai.com/princy-api/   -> :3210  API agente (proxy)
#   https://dashboard.princyai.com/    -> :3210  dashboard + chat
# =============================================================================

# --- Banco e sessao (localhost = so no VPS) ---
DATABASE_URL="postgresql://ai_dashboard:ai_dashboard@localhost:5432/ai_dashboard?schema=public"
SESSION_SECRET="troque-por-segredo-longo-min-32-chars"

# --- Rede VPS ---
PRINCY_VPS_HOST="108.181.169.40"
INDEX_PORT="3220"
API_HOST="0.0.0.0"
API_PORT="3210"

# Origem publica (HTTPS) — CORS e cookies do dashboard
APP_ORIGIN="https://princyai.com"

# Editor Code Web
# CODE_WEB_INTERNAL_URL = probes no VPS (porta 3200, sem Caddy)
# CODE_WEB_URL = URL publica com /webeditor (health environment=production)
PRINCY_EDITOR_BASE_PATH="/webeditor"
CODE_WEB_INTERNAL_URL="http://108.181.169.40:3200"
CODE_WEB_URL="https://princyai.com/webeditor"

# CORS: dominios publicos + portas internas do VPS (sem typo em .com)
PRINCY_CORS_ORIGINS="https://princyai.com,https://www.princyai.com,https://dashboard.princyai.com,http://108.181.169.40:3200,http://108.181.169.40:3220,http://127.0.0.1:3200"

# --- Pastas no VPS ---
WORKSPACE_STORAGE_ROOT="C:/Apps/Editor/apps/ai-dashboard/workspace-storage"
EDITOR_PROJECT_ROOT="C:/Apps/Editor"

# --- IA: Groq = rapido (recomendado). Ollama so se rodar local no VPS ---
AI_PROVIDER="groq"
GROQ_API_KEY="gsk_sua_chave_groq"
GROQ_BASE_URL="https://api.groq.com/openai/v1"
GROQ_CHAT_MODEL="llama-3.1-8b-instant"

OPENAI_API_KEY=""
OPENAI_CHAT_MODEL="gpt-4o-mini"
OPENAI_EMBEDDING_MODEL="text-embedding-3-small"
GOOGLE_AI_API_KEY=""
DEEPSEEK_API_KEY=""
DEEPSEEK_BASE_URL="https://api.deepseek.com"
HUGGINGFACE_API_KEY=""

OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_CHAT_MODEL="deepseek-coder"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
PRINCY_OLLAMA_NUM_PREDICT="512"
PRINCY_OLLAMA_NUM_CTX="2048"

# --- Desempenho: chat/editor leves (sem RAG/orquestrador/jobs pesados) ---
PRINCY_SIMPLE_MODE="true"
PRINCY_RAG_ENABLED="false"
PRINCY_PROJECT_RAG_INDEXING="false"
PRINCY_SHADOW_CONTEXT="false"
PRINCY_TERMINAL_CONTEXT="false"
PRINCY_AUTO_DIFF="false"
PRINCY_REQUIRE_APPROVAL="false"
PRINCY_ORCHESTRATOR_ENABLED="false"
PRINCY_ORCHESTRATOR_CONSENSUS="false"
PRINCY_ORCHESTRATOR_AUTO_HEAL="false"
PRINCY_AUTO_COMPILE_VALIDATE="false"
PRINCY_AGENT_ASYNC_JOBS="false"
PRINCY_AGENT_STREAM_TOKENS="true"
PRINCY_PUBLIC_CHAT="true"
PRINCY_CORS_RELAXED="false"

RAG_MAX_CHUNKS="4"
RAG_CHUNK_SIZE="800"

# --- Agente / editor ---
# Vazio + PRINCY_PUBLIC_CHAT=true = webeditor sem Bearer (producao atual).
# Se definir token, use o MESMO valor em princyai.apiToken (.princy-user-data/User/settings.json).
AGENT_API_TOKEN=""
AGENT_WORKSPACE_NAME="Princy Ai Web"
