# Copie para C:\Apps\Editor\apps\ai-dashboard\.env no VPS
# Ajuste SESSION_SECRET e senha do Postgres antes de producao.

DATABASE_URL="postgresql://ai_dashboard:ai_dashboard@localhost:5432/ai_dashboard?schema=public"
SESSION_SECRET="troque-por-um-segredo-longo-aleatorio-min-32-chars"

APP_ORIGIN="https://princyai.com"
API_HOST="0.0.0.0"
API_PORT="3210"

WORKSPACE_STORAGE_ROOT="C:/Apps/Editor/apps/ai-dashboard/workspace-storage"
EDITOR_PROJECT_ROOT="C:/Apps/Editor"

# groq = chat rapido (recomendado VPS) | ollama = local CPU
AI_PROVIDER="groq"
GROQ_API_KEY="gsk_sua_chave_aqui"
GROQ_CHAT_MODEL="llama-3.1-8b-instant"
GROQ_BASE_URL="https://api.groq.com/openai/v1"

OLLAMA_BASE_URL="http://127.0.0.1:11434"
OLLAMA_CHAT_MODEL="phi3:mini"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"

# Chat rapido no dashboard (desliga orquestrador/RAG pesado)
PRINCY_SIMPLE_MODE="true"
PRINCY_RAG_ENABLED="false"
PRINCY_OLLAMA_NUM_PREDICT="1024"
PRINCY_OLLAMA_NUM_CTX="2048"
PRINCY_PUBLIC_CHAT="true"

PRINCY_VPS_HOST="108.181.169.40"
INDEX_PORT="3220"

# Editor em /webeditor (landing do dominio raiz fica na porta 3220)
CODE_WEB_INTERNAL_URL="http://108.181.169.40:3200"
CODE_WEB_URL="http://108.181.169.40:3200/webeditor"
PRINCY_EDITOR_BASE_PATH="/webeditor"
PRINCY_CORS_ORIGINS="https://princyai.com,https://www.princyai.com,https://dashboard.princyai.com,http://108.181.169.40:3200,http://108.181.169.40:3220"

AGENT_API_TOKEN=""
AGENT_WORKSPACE_NAME="Princy Ai Web"

OPENAI_API_KEY=""
GROQ_API_KEY=""
GOOGLE_AI_API_KEY=""
DEEPSEEK_API_KEY=""
HUGGINGFACE_API_KEY=""

RAG_MAX_CHUNKS="6"
RAG_CHUNK_SIZE="1200"
