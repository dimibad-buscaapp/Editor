# Copie para apps/ai-dashboard/.env ao testar Code Web em http://127.0.0.1:3200 no VPS (RDP).
# Mantenha producao (https://princyai.com) em princyai.env.example.

DATABASE_URL="postgresql://ai_dashboard:ai_dashboard@localhost:5432/ai_dashboard?schema=public"
SESSION_SECRET="replace-with-a-long-random-production-secret"

# Origem do editor no browser — deve bater com a URL que voce abre
APP_ORIGIN="http://127.0.0.1:3200"
CODE_WEB_URL="http://127.0.0.1:3200"

# Origens extras (virgula, sem espacos) se usar dominio + local ao mesmo tempo
PRINCY_CORS_ORIGINS="https://princyai.com,https://www.princyai.com"

# Opcional: libera qualquer origem (somente desenvolvimento)
# PRINCY_CORS_RELAXED="true"

API_HOST="127.0.0.1"
API_PORT="3210"
AI_PROVIDER="ollama"
OLLAMA_BASE_URL="http://localhost:11434"
OLLAMA_CHAT_MODEL="deepseek-coder"
OLLAMA_EMBEDDING_MODEL="nomic-embed-text"
EDITOR_PROJECT_ROOT="C:/Apps/Editor"
AGENT_API_TOKEN=""
AGENT_WORKSPACE_NAME="Princy Ai Web"

# Modo leve: chat direto sem RAG/shadow/terminal/diff no boot
PRINCY_SIMPLE_MODE=1
PRINCY_RAG_ENABLED=0
PRINCY_TERMINAL_CONTEXT=0
PRINCY_AUTO_DIFF=0
PRINCY_REQUIRE_APPROVAL=0
PRINCY_SHADOW_CONTEXT=0
PRINCY_PROJECT_RAG_INDEXING=0
PRINCY_AGENT_ASYNC_JOBS=0
PRINCY_ORCHESTRATOR_ENABLED=0
PRINCY_AUTO_COMPILE_VALIDATE=0
