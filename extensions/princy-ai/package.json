{
  "name": "princy-ai",
  "displayName": "Princy Ai",
  "description": "AI coding agent for Princy Ai Code-OSS Web.",
  "version": "0.1.0",
  "publisher": "princyai",
  "license": "MIT",
  "engines": {
    "vscode": "^1.100.0"
  },
  "main": "./out/extension",
  "browser": "./dist/browser/extension",
  "categories": [
    "AI",
    "Themes",
    "Other"
  ],
  "extensionKind": [
    "ui"
  ],
  "activationEvents": [
    "*",
    "onStartupFinished",
    "onCommand:princyai.open",
    "onCommand:princyai.inlineEdit",
    "onCommand:princyai.chat.focus",
    "onCommand:princyai.composer",
    "onCommand:princyai.native.collectContext",
    "onCommand:princyai.indexActiveFile",
    "onCommand:princyai.indexWorkspace",
    "onView:princyai.chat"
  ],
  "capabilities": {
    "virtualWorkspaces": true,
    "untrustedWorkspaces": {
      "supported": true
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "princyai.inlineEdit",
        "title": "Ask Princy",
        "category": "Princy Ai",
        "icon": "$(sparkle)"
      },
      {
        "command": "princyai.ui.resetLayout",
        "title": "Reset Princy Layout (unlock editor + chat docked)",
        "category": "Princy Ai"
      },
      {
        "command": "princyai.chat.focus",
        "title": "Focus Chat",
        "category": "Princy Ai",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "princyai.open",
        "title": "Open Princy Ai",
        "category": "Princy Ai",
        "icon": "$(sparkle)"
      },
      {
        "command": "princyai.composer",
        "title": "Open Composer",
        "category": "Princy Ai",
        "icon": "$(diff-multiple)"
      },
      {
        "command": "princyai.indexActiveFile",
        "title": "Index Active File",
        "category": "Princy Ai",
        "icon": "$(database)"
      },
      {
        "command": "princyai.runSuggestedCommand",
        "title": "Run Suggested Command",
        "category": "Princy Ai",
        "icon": "$(terminal)"
      },
      {
        "command": "princyai.native.collectContext",
        "title": "Collect Native Context",
        "category": "Princy Ai",
        "icon": "$(symbol-namespace)"
      },
      {
        "command": "princyai.indexWorkspace",
        "title": "Index Workspace for RAG",
        "category": "Princy Ai",
        "icon": "$(database)"
      },
      {
        "command": "princyai.reconnectBackend",
        "title": "Reconnect Agent Backend",
        "category": "Princy Ai",
        "icon": "$(refresh)"
      }
    ],
    "keybindings": [
      {
        "command": "princyai.open",
        "key": "ctrl+shift+l",
        "mac": "cmd+shift+l"
      },
      {
        "command": "princyai.inlineEdit",
        "key": "ctrl+k ctrl+i",
        "mac": "cmd+k cmd+i",
        "when": "editorTextFocus && editorHasSelection && !editorReadonly"
      },
      {
        "command": "princyai.chat.focus",
        "key": "ctrl+l",
        "mac": "cmd+l"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "command": "princyai.inlineEdit",
          "when": "editorHasSelection && !editorReadonly",
          "group": "princyai@1",
          "title": "Ask Princy"
        },
        {
          "command": "princyai.indexActiveFile",
          "when": "editorTextFocus",
          "group": "princyai@2"
        }
      ],
      "commandPalette": [
        {
          "command": "princyai.inlineEdit"
        },
        {
          "command": "princyai.chat.focus"
        },
        {
          "command": "princyai.open"
        },
        {
          "command": "princyai.composer"
        },
        {
          "command": "princyai.indexActiveFile"
        },
        {
          "command": "princyai.runSuggestedCommand"
        },
        {
          "command": "princyai.native.collectContext"
        }
      ]
    },
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "princyai",
          "title": "Chat",
          "icon": "$(sparkle)"
        }
      ]
    },
    "views": {
      "princyai": [
        {
          "type": "webview",
          "id": "princyai.chat",
          "name": "Chat",
          "icon": "$(sparkle)"
        }
      ]
    },
    "themes": [
      {
        "id": "Princy Black",
        "label": "Princy Black",
        "uiTheme": "vs-dark",
        "path": "./themes/princy-black-color-theme.json"
      }
    ],
    "configurationDefaults": {
      "chat.disableAIFeatures": true,
      "chat.agentsControl.enabled": "hidden",
      "chat.agent.enabled": false,
      "chat.agentHost.enabled": false,
      "chat.generalPurposeAgent.enabled": false,
      "chat.viewSessions.enabled": false,
      "chat.unifiedAgentsBar.enabled": false,
      "chat.restoreLastPanelSession": false,
      "chat.titleBar.signIn.enabled": false,
      "workbench.secondarySideBar.defaultVisibility": "visible",
      "workbench.secondarySideBar.forceMaximized": false,
      "princyai.ui.openChatOnStartup": true,
      "princyai.ui.defaultChat": true,
      "princyai.useSameOriginApi": true,
      "princyai.agentEndpoint": "/princy-api",
      "princyai.chat.simpleMode": false,
      "princyai.actionRun.approvalRequired": true,
      "princyai.actionRun.autoCompileAfterApply": true,
      "princyai.composer.autoVerify": false,
      "princyai.builder.defaultTarget": "web",
      "princyai.projects.root": "workspace-storage/projetos",
      "princyai.workspaceIndex.onOpen": true,
      "window.commandCenter": true,
      "window.title": "${rootName}",
      "workbench.panel.defaultLocation": "bottom",
      "workbench.panel.opensMaximized": "never",
      "workbench.tree.indent": 12,
      "editor.inlineSuggest.enabled": true,
      "workbench.colorTheme": "Princy Black",
      "workbench.preferredDarkColorTheme": "Princy Black",
      "editor.fontFamily": "'JetBrains Mono', 'Cascadia Code', Consolas, monospace",
      "workbench.activityBar.location": "default",
      "princyai.ui.minimalWorkbench": false,
      "princyai.chat.dockedRight": true,
      "editor.minimap.enabled": false,
      "editor.glyphMargin": false,
      "editor.scrollBeyondLastLine": false,
      "editor.smoothScrolling": true,
      "workbench.layoutControl.enabled": true,
      "workbench.startupEditor": "none",
      "workbench.welcomePage.experimentalOnboarding": false,
      "editor.centeredLayoutAutoResize": false,
      "window.menuBarVisibility": "classic",
      "breadcrumbs.enabled": true,
      "files.readonlyInclude": {},
      "files.readonlyFromPermissions": false,
      "workbench.activityBar.visible": true,
      "princyai.defaultAgent": "deepseek",
      "princyai.ghostText.agent": "deepseek"
    },
    "configuration": {
      "title": "Princy Ai",
      "properties": {
        "princyai.agentEndpoint": {
          "type": "string",
          "default": "/princy-api",
          "description": "URL da API do agent backend. Em producao use /princy-api (same-origin). URL absoluta opcional: https://princyai.com/princy-api."
        },
        "princyai.useSameOriginApi": {
          "type": "boolean",
          "default": true,
          "description": "No navegador, tenta /princy-api no mesmo dominio do editor antes de localhost:3210."
        },
        "princyai.apiToken": {
          "type": "string",
          "default": "",
          "description": "Optional API token sent to the Princy Ai agent backend."
        },
        "princyai.autoIndexOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-index files in the AI backend when they are saved."
        },
        "princyai.ghostText.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Show Princy Ai ghost text (inline completions) while typing."
        },
        "princyai.ghostText.agent": {
          "type": "string",
          "enum": ["princy", "deepseek", "qwen", "codellama", "llama3", "mistral", "openai"],
          "default": "deepseek",
          "description": "Agent used for ghost text completions."
        },
        "princyai.ghostText.debounceMs": {
          "type": "number",
          "default": 650,
          "minimum": 200,
          "maximum": 3000,
          "description": "Delay in milliseconds before requesting a ghost text suggestion."
        },
        "princyai.ghostText.prefixLines": {
          "type": "number",
          "default": 36,
          "minimum": 8,
          "maximum": 120,
          "description": "Number of lines before the cursor sent as context."
        },
        "princyai.ui.forceBlackTheme": {
          "type": "boolean",
          "default": true,
          "description": "Apply the Princy Black color theme on startup."
        },
        "princyai.ui.minimalWorkbench": {
          "type": "boolean",
          "default": false,
          "description": "Simplify workbench UI (Cursor-like: no minimap, compact menu)."
        },
        "princyai.chat.dockedRight": {
          "type": "boolean",
          "default": true,
          "description": "Keep Princy Chat docked in the right auxiliary bar (never maximized fullscreen)."
        },
        "princyai.ui.defaultChat": {
          "type": "boolean",
          "default": true,
          "description": "Hide built-in VS Code chat and open Princy Ai as the default chat panel."
        },
        "princyai.ui.openChatOnStartup": {
          "type": "boolean",
          "default": true,
          "description": "Open the Princy Chat panel in the right sidebar when the workbench loads (Cursor-like)."
        },
        "princyai.defaultAgent": {
          "type": "string",
          "enum": ["princy", "deepseek", "qwen", "codellama", "llama3", "mistral", "openai"],
          "default": "deepseek",
          "description": "Default AI engine for Princy Ai chat and Composer (DeepSeek recommended)."
        },
        "princyai.chat.simpleMode": {
          "type": "boolean",
          "default": false,
          "description": "Use POST /api/agent/chat (sync) without jobs, RAG, shadow context or VPS compile on each message."
        },
        "princyai.actionRun.approvalRequired": {
          "type": "boolean",
          "default": true,
          "description": "Exige aprovacao explicita antes de apply no modo Agent."
        },
        "princyai.actionRun.autoCompileAfterApply": {
          "type": "boolean",
          "default": true,
          "description": "Apos apply aprovado no Agent, dispara compile e testes no VPS."
        },
        "princyai.composer.autoVerify": {
          "type": "boolean",
          "default": false,
          "description": "No Composer, executa compile/test automaticamente apos apply (senao use Verificar)."
        },
        "princyai.builder.defaultTarget": {
          "type": "string",
          "enum": ["web", "api", "exe", "apk"],
          "default": "web",
          "description": "Alvo padrao do modo Builder."
        },
        "princyai.projects.root": {
          "type": "string",
          "default": "workspace-storage/projetos",
          "description": "Pasta de projetos (Fase 5: workspace-storage/projetos; alinhar com backend)."
        },
        "princyai.workspaceIndex.onOpen": {
          "type": "boolean",
          "default": true,
          "description": "Index workspace files for RAG shortly after opening a folder."
        }
      }
    }
  },
  "scripts": {
    "compile": "gulp compile-extension:princy-ai",
    "watch": "gulp watch-extension:princy-ai",
    "compile-web": "npm-run-all2 -lp bundle-web typecheck-web",
    "bundle-web": "node ./esbuild.browser.mts",
    "typecheck-web": "tsgo --project ./tsconfig.browser.json --noEmit",
    "watch-web": "npm-run-all2 -lp watch-bundle-web watch-typecheck-web",
    "watch-bundle-web": "node ./esbuild.browser.mts --watch",
    "watch-typecheck-web": "tsgo --project ./tsconfig.browser.json --noEmit --watch"
  }
}
