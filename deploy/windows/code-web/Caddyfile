# Princy Ai — 3 servicos no VPS (127.0.0.1)
#   Landing/Index  → 3220  (princyai.com/)
#   Code Web       → 3200  (/webeditor* — usar handle, NAO handle_path)
#   Agent API      → 3210  (/princy-api* — handle_path; dashboard; logview; /api)

{
	email dimi.bad@gmail.com
}

princyai.com, www.princyai.com {
	encode zstd gzip

	# Agent API (prefixo /princy-api removido pelo handle_path)
	handle_path /princy-api/* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Agent: Starter Log + chat em princyai.com que chama /api/*
	handle /logview* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /api/* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Fase 8: sites estaticos (preview + publicados) no agent :3210
	handle /princy-sites* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle /princy-sites-preview* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	@webeditor_root path /webeditor
	handle @webeditor_root {
		redir /webeditor/ permanent
	}

	# Code Web LIVE — opcional (porta 3201); URL principal continua /webeditor/
	@webeditor_live_root path /webeditor-live
	handle @webeditor_live_root {
		redir /webeditor-live/ permanent
	}
	handle /webeditor-live* {
		reverse_proxy 127.0.0.1:3201 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Princy-Live-Mode 1
		}
	}

	# Chat live — testa API sem workbench (agent :3210)
	handle /princy-chat-live* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Code Web — URL principal https://princyai.com/webeditor/ (porta 3200)
	handle /webeditor* {
		reverse_proxy 127.0.0.1:3200 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	# Landing / index (tudo o resto)
	handle {
		reverse_proxy 127.0.0.1:3220 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

