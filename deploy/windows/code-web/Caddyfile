# Copie para C:\Caddy\Caddyfile no VPS.
# DNS Hostinger (OBRIGATORIO apontar para o IP deste VPS, ex. 108.181.169.40):
#   A  @      -> IP do VPS
#   A  www    -> IP do VPS
#   A  dashboard -> IP do VPS
#   A  api    -> IP do VPS  (descomente bloco api.* abaixo depois)
#
# Teste: nslookup princyai.com  deve retornar o IP do VPS (nao outro IP).
# Se Let's Encrypt mostrar IP 2.57.91.91, o DNS ainda aponta para outro servidor.
#
# Antes do Caddy: backend :3210 e Code Web :3200 rodando.
# Veja deploy/windows/DOMINIO-HOSTINGER.md e PRINCY-ONLINE.md

{
	email dimi.bad@gmail.com
}

princyai.com, www.princyai.com {
	encode zstd gzip

	handle_path /princy-api/* {
		reverse_proxy 127.0.0.1:3210
	}

	reverse_proxy 127.0.0.1:3200 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}

dashboard.princyai.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:3210 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}

# Descomente quando existir registro DNS A para api.princyai.com:
# api.princyai.com {
# 	encode zstd gzip
# 	reverse_proxy 127.0.0.1:3210
# }
