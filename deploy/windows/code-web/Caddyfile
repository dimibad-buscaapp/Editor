# princyai.com/           -> index landing (3220)
# princyai.com/webeditor/ -> Code-OSS Web (3200) — --server-base-path /webeditor
# princyai.com/princy-api -> agent API (3210)
# dashboard.princyai.com  -> dashboard + chat (3210)

{
	email dimi.bad@gmail.com
}

princyai.com, www.princyai.com {
	encode zstd gzip

	handle_path /princy-api/* {
		reverse_proxy 127.0.0.1:3210
	}

	# Chat/dashboard em princyai.com/#/chat chama /api/agent/* (nao cair na landing :3220)
	handle /api/* {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	@webeditor_root path /webeditor
	handle @webeditor_root {
		redir /webeditor/ permanent
	}

	# NAO usar handle_path: o Code Web precisa receber /webeditor/... completo
	handle /webeditor* {
		reverse_proxy 127.0.0.1:3200 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle {
		reverse_proxy 127.0.0.1:3220 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

dashboard.princyai.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:3210 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}
