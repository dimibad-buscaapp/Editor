# princyai.com/           -> pagina inicial (3210)
# princyai.com/webeditor/ -> Code-OSS Web (3200) — requer --server-base-path /webeditor no Code Web
# princyai.com/princy-api -> agent (3210)

{
	email dimi.bad@gmail.com
}

princyai.com, www.princyai.com {
	encode zstd gzip

	handle_path /princy-api/* {
		reverse_proxy 127.0.0.1:3210
	}

	@webeditor_root path /webeditor
	handle @webeditor_root {
		redir /webeditor/ permanent
	}

	# NAO usar handle_path aqui: o Code Web precisa receber /webeditor/... completo
	handle /webeditor* {
		reverse_proxy 127.0.0.1:3200 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}

	handle {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

dashboard.princyai.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:3210 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}
