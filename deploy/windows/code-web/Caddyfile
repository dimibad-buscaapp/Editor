# Copie para C:\Caddy\Caddyfile no VPS.
# princyai.com/           -> pagina inicial (hub, porta 3210)
# princyai.com/webeditor/ -> Code-OSS Web (porta 3200)
# princyai.com/princy-api -> agent backend (porta 3210)
# dashboard.princyai.com  -> chat + dashboard (porta 3210)

{
	email dimi.bad@gmail.com
}

princyai.com, www.princyai.com {
	encode zstd gzip

	handle_path /princy-api/* {
		reverse_proxy 127.0.0.1:3210
	}

	@webeditor_root path /webeditor
	handle @webeditor_root {
		redir /webeditor/ permanent
	}

	handle_path /webeditor/* {
		reverse_proxy 127.0.0.1:3200 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
			header_up X-Forwarded-Prefix /webeditor
		}
	}

	handle {
		reverse_proxy 127.0.0.1:3210 {
			header_up Host {host}
			header_up X-Forwarded-Host {host}
			header_up X-Forwarded-Proto {scheme}
		}
	}
}

dashboard.princyai.com {
	encode zstd gzip
	reverse_proxy 127.0.0.1:3210 {
		header_up Host {host}
		header_up X-Forwarded-Host {host}
		header_up X-Forwarded-Proto {scheme}
	}
}
